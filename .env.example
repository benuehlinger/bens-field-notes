# Ben's Field Notes — Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.

# Cloudflare R2 — public bucket base URL OR Cloudflare Worker signed URL endpoint
# Format: https://your-bucket.r2.dev  (if bucket is public)
# Format: https://your-worker.your-subdomain.workers.dev  (if using Worker for signed URLs)
R2_BASE_URL=

# Cloudflare R2 credentials (only needed for data lake pipelines, NOT for the site)
# The site reads R2 data via public URL or Worker — it never uses these credentials
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
